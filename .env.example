# Spectra-Web environment — copy to `.env` and fill in.
# Used by the anonymous telemetry ingest + admin dashboard.

# Password for the /admin telemetry dashboard. Generate a long random value, e.g.
#   openssl rand -hex 32
# Required — without it /admin and the stats API stay locked.
ADMIN_TOKEN=

# Optional soft anti-spam key. If set, the launcher must send the same value in
# the `x-spectra-key` header (set INGEST_KEY in the launcher's useTelemetry.ts to
# match). Leave empty to accept any client.
SPECTRA_INGEST_KEY=

# Where the SQLite telemetry file lives. Default is ./data/telemetry.db.
# In Docker, mount a volume on this path so data survives redeploys.
TELEMETRY_DB_PATH=./data/telemetry.db
